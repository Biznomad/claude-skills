<div class="custom-section" style="
  background: {{ section.settings.bg_color }};
  padding: 48px 20px;
">
  <div class="page-width" style="max-width: 1000px; margin: 0 auto;">
    {%- if section.settings.heading != blank -%}
      <h2 style="
        text-align: center;
        font-size: 1.6rem;
        font-weight: 700;
        color: #1a1a1a;
        margin: 0 0 32px;
      ">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    <div class="custom-section__grid" style="
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 24px;
    ">
      {%- for block in section.blocks -%}
        <div class="custom-section__item" style="
          background: #ffffff;
          border-radius: 12px;
          padding: 24px;
          box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
        " {{ block.shopify_attributes }}>
          {%- if block.settings.icon != blank -%}
            <div style="font-size: 1.8rem; margin-bottom: 8px;">
              {{ block.settings.icon }}
            </div>
          {%- endif -%}
          <h3 style="font-size: 1.05rem; font-weight: 700; margin: 0 0 8px;">
            {{ block.settings.title }}
          </h3>
          <p style="font-size: 0.9rem; color: #555; line-height: 1.5; margin: 0;">
            {{ block.settings.description }}
          </p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  @media (max-width: 600px) {
    .custom-section__grid {
      grid-template-columns: 1fr !important;
      gap: 16px !important;
    }
  }
</style>

{% schema %}
{
  "name": "Custom Section",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Section Heading"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "limit": 12,
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Emoji icon",
          "default": "✅"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Describe this feature."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Section",
      "blocks": [
        { "type": "item", "settings": { "icon": "✅", "title": "Feature 1", "description": "Description of feature 1." } },
        { "type": "item", "settings": { "icon": "⭐", "title": "Feature 2", "description": "Description of feature 2." } },
        { "type": "item", "settings": { "icon": "🚀", "title": "Feature 3", "description": "Description of feature 3." } }
      ]
    }
  ]
}
{% endschema %}
